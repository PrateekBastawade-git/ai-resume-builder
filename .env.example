# ================================================================
# AI Resume Builder — Environment Variables Template
# ================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# ================================================================

# ----------------------------
# Backend: Groq AI API Key
# (Required for all AI features)
# Get yours at: https://console.groq.com/keys
# ----------------------------
GROQ_API_KEY=your_groq_api_key_here

# ----------------------------
# Frontend: Supabase Configuration
# (Required for user authentication & cloud resume sync)
# Get yours at: https://supabase.com/dashboard
# ----------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ----------------------------
# Backend Port (Optional — defaults to 3001)
# ----------------------------
PORT=3001
